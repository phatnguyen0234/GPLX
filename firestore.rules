rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    // Cho phép mọi người đọc, chỉ user đăng nhập mới được ghi
    match /attempts/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /exam_sessions/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Thêm rule cho practice_sessions
    match /practice_sessions/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /bookmarks/{docId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.user_id;
      allow write: if request.auth != null && request.auth.uid == request.resource.data.user_id;
    }

    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /question_meta/{qid} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Mặc định: chặn những collection khác
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
