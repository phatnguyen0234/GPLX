<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/ripple_primary">
    <item>
        <selector>
            <item android:state_enabled="false">
                <shape android:shape="rectangle">
                    <solid android:color="@color/button_primary_disabled" />
                    <corners android:radius="@dimen/radius_button" />
                </shape>
            </item>
            <item android:state_pressed="true">
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="@color/button_primary_pressed"
                        android:endColor="@color/color_primary"
                        android:angle="135" />
                    <corners android:radius="@dimen/radius_button" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="@color/color_primary"
                        android:endColor="@color/color_primary_variant"
                        android:angle="135" />
                    <corners android:radius="@dimen/radius_button" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>

