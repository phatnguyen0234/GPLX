<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_page_horizontal"
            android:paddingTop="80dp"
            android:paddingBottom="88dp">

            <!-- Header Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.App.Card.Large"
                android:layout_marginBottom="@dimen/spacing_section_vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_page_horizontal">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/TextDashboardTitle"
                        android:text="Ôn thông minh (AI)"
                        android:textColor="@color/color_text_primary" />

            <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/TextBody"
                        android:layout_marginTop="8dp"
                        android:text="AI ưu tiên câu yếu, câu điểm liệt và câu đến hạn cho bạn."
                        android:textColor="@color/color_text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Form Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.App.Card.Large"
                android:layout_marginBottom="@dimen/spacing_section_vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_page_horizontal">

                    <!-- Chế độ -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/TextSectionTitle"
                android:text="Chế độ"
                        android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/sp_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_item_vertical"
                        android:background="@drawable/bg_spinner"
                        android:padding="12dp" />

                    <!-- Chủ đề -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                        style="@style/TextSectionTitle"
                android:text="Chủ đề"
                        android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/sp_topic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_item_vertical"
                        android:background="@drawable/bg_spinner"
                        android:padding="12dp" />

                    <!-- Số câu hỏi -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                        style="@style/TextSectionTitle"
                android:text="Số câu hỏi"
                        android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/sp_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_item_vertical"
                        android:background="@drawable/bg_spinner"
                        android:padding="12dp" />

                    <!-- Checkbox -->
            <CheckBox
                android:id="@+id/cb_critical_only"
                        android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ưu tiên các câu điểm liệt"
                android:textColor="@color/color_text_primary"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginBottom="@dimen/spacing_item_vertical" />

                    <!-- Meta Summary -->
            <TextView
                android:id="@+id/txt_meta_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                        style="@style/TextBody"
                android:textColor="@color/color_text_secondary"
                        android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

                    <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/pb_loading"
                style="?android:attr/progressBarStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />
        </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Buttons Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.App.Card.Large">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
                    android:padding="@dimen/spacing_page_horizontal">

                    <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_due_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Xem danh sách đến hạn"
                        style="@style/ButtonSecondary"
                        android:layout_marginBottom="@dimen/spacing_item_vertical"
                        android:minHeight="@dimen/button_height" />

                    <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_smart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bắt đầu ôn thông minh"
                        style="@style/ButtonPrimary"
                        android:minHeight="@dimen/button_height" />
    </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

</LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/color_surface"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:title="Ôn thông minh (AI)"
            app:titleTextColor="@color/color_text_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Bottom App Bar - Nomadstay Style -->
    <com.google.android.material.bottomappbar.BottomAppBar
        android:id="@+id/bottom_app_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/height_bottom_bar"
        android:layout_gravity="bottom"
        app:backgroundTint="@color/color_surface"
        app:elevation="@dimen/elev_bottom_bar"
        app:menu="@menu/bottom_nav_menu"
        app:navigationIcon="@null"
        app:itemIconTint="@color/bottom_nav_icon_selector"
        app:itemTextColor="@color/bottom_nav_text_selector" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
