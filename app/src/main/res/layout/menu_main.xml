<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_popup"
    android:orientation="vertical">

    <TextView
        android:id="@+id/txtMenuTopic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:drawableLeft="@android:drawable/ic_menu_agenda"
        android:drawablePadding="12dp"
        android:padding="16dp"
        android:text="Ôn tập theo chủ đề"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/txtMenuLevel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:drawableLeft="@android:drawable/ic_menu_recent_history"
        android:drawablePadding="12dp"
        android:padding="16dp"
        android:text="Thi thử"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/textView7"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:drawableLeft="@android:drawable/ic_menu_save"
        android:drawablePadding="12dp"
        android:padding="16dp"
        android:text="Câu hỏi đã đánh dấu"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/textView9"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:drawableLeft="@android:drawable/ic_menu_recent_history"
        android:drawablePadding="12dp"
        android:padding="16dp"
        android:text="Lịch sử làm bài"
        android:textSize="20sp" />
</LinearLayout>