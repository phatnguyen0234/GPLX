<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/card_background"
    android:minWidth="300dp">

    <TextView
        android:id="@+id/txt_explanation_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Vì sao câu này được chọn?"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lý do:"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/txt_reasons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="• Đến hạn\n• P(correct) thấp\n• Câu liệt"
        android:textSize="14sp"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Thông tin chi tiết:"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/txt_scores"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Điểm ưu tiên: 0.75\nXác suất đúng: 45%\nĐộ khẩn cấp: 0.60"
        android:textSize="14sp"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btn_close"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Đóng"
        android:background="@drawable/btn_primary"
        android:textColor="@color/button_text"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingTop="12dp"
        android:paddingBottom="12dp" />

</LinearLayout>

