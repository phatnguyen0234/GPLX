<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_page_horizontal"
            android:paddingTop="80dp"
            android:paddingBottom="100dp">

            <!-- Stats Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.App.Card.Large"
                android:layout_marginBottom="@dimen/spacing_section_vertical"
                android:contentDescription="@string/app_name">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_page_horizontal">

                    <TextView
                        android:id="@+id/txt_review_stats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/TextSectionTitle"
                        android:text="Kết quả: 0/0"
                        android:textColor="@color/color_text_primary"
                        android:minHeight="48dp"
                        android:gravity="center_vertical" />

                    <TextView
                        android:id="@+id/txt_review_time"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/TextCaption"
                        android:layout_marginTop="4dp"
                        android:text="Từ: -- đến --"
                        android:textColor="@color/color_text_secondary"
                        android:minHeight="40dp"
                        android:gravity="center_vertical" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Questions List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_review_questions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingBottom="@dimen/spacing_section_vertical"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/color_surface"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:title="Xem lại bài làm"
            app:titleTextColor="@color/color_text_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Bottom Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_review_done"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="@dimen/spacing_page_horizontal"
        style="@style/ButtonPrimary"
        android:text="Xong"
        android:minHeight="56dp"
        android:contentDescription="@string/app_name" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>

