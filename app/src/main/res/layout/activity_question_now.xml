<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    tools:context=".QuestionActivityNow">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_primary"
        android:elevation="0dp"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="?attr/actionBarSize"
            android:background="@color/color_primary"
            app:titleTextColor="@color/color_on_primary"
            app:title="">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingEnd="16dp">

                <ImageButton
                    android:id="@+id/btnBackQAN"
                    android:layout_width="@dimen/touch_target_min"
                    android:layout_height="@dimen/touch_target_min"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_arrow_back"
                    android:contentDescription="@string/nav_back"
                    app:tint="@color/color_on_primary" />

                <TextView
                    android:id="@+id/txtTopicQAN"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Hạng A"
                    android:textColor="@color/color_on_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtQANtimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20:00"
                    android:textColor="@color/color_on_primary"
                    android:textSize="16sp"
                    android:layout_marginEnd="12dp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/iv_bookmark_button"
                    android:layout_width="@dimen/touch_target_min"
                    android:layout_height="@dimen/touch_target_min"
                    android:layout_marginEnd="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/bookmark"
                    android:padding="12dp"
                    android:src="@drawable/ic_bookmark_border"
                    app:tint="@color/color_on_primary" />

                <Button
                    android:id="@+id/btnQAN_submit"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nộp bài"
                    android:textSize="14sp"
                    android:textColor="@color/color_on_primary"
                    app:strokeColor="@color/color_on_primary"
                    app:strokeWidth="1dp" />

            </LinearLayout>

        </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_page_horizontal">

            <!-- Question Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_section_vertical"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="@dimen/radius_card_large"
                app:cardElevation="@dimen/elev_card"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Question Content -->
                    <TextView
                        android:id="@+id/txtQANcontent"
                        style="@style/TextBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Phần của đường bộ được sử dụng cho phương tiện giao thông đường bộ đi lại là gì?"
                        android:textSize="16sp"
                        android:textColor="@color/color_text_primary"
                        android:textStyle="bold"
                        android:lineSpacingMultiplier="1.4" />

                    <!-- Question Image -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/img_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="@dimen/radius_thumbnail"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/imgQAN"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:adjustViewBounds="true"
                            android:scaleType="fitCenter"
                            android:contentDescription="Hình minh họa câu hỏi"
                            tools:srcCompat="@tools:sample/backgrounds/scenic" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Answer Options -->
                    <TextView
                        style="@style/TextBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Chọn đáp án:"
                        android:textSize="14sp"
                        android:textColor="@color/color_text_secondary"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <RadioGroup
                        android:id="@+id/radioBtnQAN"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <RadioButton
                            android:id="@+id/radiobtnQANa"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:text="A. Phần mặt đường và lề đường."
                            android:textSize="15sp"
                            android:textColor="@color/color_text_primary"
                            android:padding="14dp"
                            android:background="@drawable/answer_state"
                            android:lineSpacingMultiplier="1.3"
                            android:button="@null" />

                        <RadioButton
                            android:id="@+id/radiobtnQANb"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:text="B. Phần đường xe chạy."
                            android:textSize="15sp"
                            android:textColor="@color/color_text_primary"
                            android:padding="14dp"
                            android:background="@drawable/answer_state"
                            android:lineSpacingMultiplier="1.3"
                            android:button="@null" />

                        <RadioButton
                            android:id="@+id/radiobtnQANc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:background="@drawable/answer_state"
                            android:button="@null"
                            android:padding="14dp"
                            android:text="C. Khổ giới hạn của đường bộ."
                            android:textColor="@color/color_text_primary"
                            android:textSize="15sp"
                            android:lineSpacingMultiplier="1.3" />

                        <RadioButton
                            android:id="@+id/radiobtnQANd"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:text="D. Đáp án D"
                            android:textSize="15sp"
                            android:textColor="@color/color_text_primary"
                            android:padding="14dp"
                            android:background="@drawable/answer_state"
                            android:lineSpacingMultiplier="1.3"
                            android:button="@null" />

                    </RadioGroup>

                    <!-- Standard Explanation Section -->
                    <LinearLayout
                        android:id="@+id/explanation_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="20dp"
                        android:padding="16dp"
                        android:background="@drawable/bg_card_rounded"
                        android:visibility="gone">

                        <TextView
                            style="@style/TextBody"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Giải thích"
                            android:textSize="14sp"
                            android:textColor="@color/color_text_secondary"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/txtQANexplain"
                            style="@style/TextBody"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="@color/color_text_primary"
                            android:lineSpacingMultiplier="1.4" />

                    </LinearLayout>

                    <!-- AI Explanation Section -->
                    <LinearLayout
                        android:id="@+id/ai_explanation_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp"
                        android:padding="16dp"
                        android:background="@drawable/bg_card_rounded"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_lightbulb"
                                app:tint="@color/color_primary"
                                android:contentDescription="AI" />

                            <TextView
                                style="@style/TextBody"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="8dp"
                                android:text="Giải thích AI"
                                android:textSize="14sp"
                                android:textColor="@color/color_primary"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/txtAIExplain"
                            style="@style/TextBody"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Nhấn nút &quot;Tạo giải thích&quot; bên dưới để AI phân tích chi tiết câu hỏi này."
                            android:textSize="14sp"
                            android:textColor="@color/color_text_secondary"
                            android:lineSpacingMultiplier="1.4" />

                        <ProgressBar
                            android:id="@+id/progressAI"
                            style="?android:attr/progressBarStyle"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:layout_marginTop="12dp"
                            android:visibility="gone"
                            android:indeterminateTint="@color/color_primary" />

                        <Button
                            android:id="@+id/btnAIExplain"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/touch_target_min"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="12dp"
                            android:text="Tạo giải thích"
                            android:textSize="14sp"
                            app:icon="@drawable/ic_lightbulb"
                            app:iconSize="18dp"
                            app:backgroundTint="@color/color_primary"
                            android:textColor="@color/color_on_primary" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Bottom Action Button -->
            <Button
                android:id="@+id/btnnextQAN"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="@dimen/touch_target_medium"
                android:text="Kiểm tra"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/color_primary"
                android:textColor="@color/color_on_primary"
                app:cornerRadius="@dimen/radius_button" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>