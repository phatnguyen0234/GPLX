<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    style="@style/Widget.App.Card.Large"
    android:layout_marginBottom="@dimen/spacing_item_vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_item_vertical">

        <!-- Exam Name -->
        <TextView
            android:id="@+id/txt_exam_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            style="@style/TextSectionTitle"
            android:text="Thi thử hạng B2"
            android:textColor="@color/color_text_primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/badge_status" />

        <!-- Status Badge -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/badge_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/color_success"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/txt_exam_name"
            app:layout_constraintBottom_toBottomOf="@id/txt_exam_name">

            <TextView
                android:id="@+id/txt_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextBadge"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="Đạt"
                android:textColor="@android:color/white"
                android:textSize="11sp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Date Time -->
        <TextView
            android:id="@+id/txt_date_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            style="@style/TextCaption"
            android:layout_marginTop="6dp"
            android:text="17/12/2024 14:30"
            android:textColor="@color/color_text_secondary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txt_exam_name"
            app:layout_constraintEnd_toStartOf="@id/txt_score" />

        <!-- Score -->
        <TextView
            android:id="@+id/txt_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/TextBody"
            android:text="25/25"
            android:textColor="@color/color_primary"
            android:textStyle="bold"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/txt_date_time"
            app:layout_constraintBottom_toBottomOf="@id/txt_date_time" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>

