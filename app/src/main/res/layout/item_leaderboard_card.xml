<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    style="@style/Widget.App.Card.Large"
    android:layout_marginBottom="@dimen/spacing_item_vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_item_vertical">

        <!-- Rank Badge -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/badge_rank"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/color_primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/txt_rank"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="1"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="18sp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Display Name -->
        <TextView
            android:id="@+id/txt_display_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            style="@style/TextSectionTitle"
            android:layout_marginStart="12dp"
            android:text="Nguyễn Văn A"
            android:textColor="@color/color_text_primary"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/badge_rank"
            app:layout_constraintTop_toTopOf="@id/badge_rank"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Stats -->
        <TextView
            android:id="@+id/txt_stats"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            style="@style/TextCaption"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:text="Best: 25 • Avg: 23.5 • 10 lần thi"
            android:textColor="@color/color_text_secondary"
            app:layout_constraintStart_toEndOf="@id/badge_rank"
            app:layout_constraintTop_toBottomOf="@id/txt_display_name"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/badge_rank" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>

